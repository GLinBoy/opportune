root=true

# Java, Groovy, Kotlin, and XML files
[*.{groovy,java,xml}]
indent_style = tab
indent_size = 2

# Kotlin files (including Kotlin scripts)
[*.{kt,kts}]
indent_style = tab
indent_size = 2

# YAML files (Spring Boot configuration files)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Web frontend files
[*.{html,htm}]
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

# JSON files (configuration, package files)
[*.json]
indent_style = space
indent_size = 2

# Gradle files (Groovy-based)
[*.gradle]
indent_style = space
indent_size = 2

# Properties files
[*.properties]
indent_style = space
indent_size = 2

# SQL files
[*.sql]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Common configuration for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
